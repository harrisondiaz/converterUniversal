{
  "name": "converter-universal",
  "version": "1.0.0",
  "description": "Universal media downloader for YouTube, TikTok, Instagram and more",
  "main": "electron/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "web": "node server/web.js",
    "setup": "node scripts/setup-ytdlp.js",
    "build:vercel": "node scripts/setup-ytdlp.js --linux"
  },
  "keywords": [
    "youtube",
    "tiktok",
    "instagram",
    "downloader",
    "yt-dlp"
  ],
  "author": "Harrison Diaz",
  "license": "MIT",
  "devDependencies": {
    "electron": "^33.2.1"
  },
  "dependencies": {
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "@vercel/functions": "^2.0.0",
    "express": "^4.22.2"
  },
  "allowScripts": {
    "electron@33.4.11": true
  }
}
